<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f0f8ff; -fx-background: #f0f8ff;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.customWorkoutCreator.CustomWorkoutCreatorController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="20.0">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>
            <children>
                <HBox maxWidth="600.0">
                    <Button onAction="#handleBack" text="←  Back to Workouts" style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-cursor: hand; -fx-font-size: 16px; -fx-font-weight: bold;" />
                </HBox>
                <VBox maxWidth="600.0" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 40;">
                    <effect><DropShadow blurType="THREE_PASS_BOX" color="#0000001a" radius="10" /></effect>
                    <Label text="Create Custom Workout" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #1e3a5f;" />
                    <VBox spacing="8.0">
                        <Label text="Workout Name" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;" />
                        <TextField fx:id="nameField" promptText="My Awesome Workout" style="-fx-padding: 15; -fx-border-color: #bae6fd; -fx-border-width: 2; -fx-background-radius: 15; -fx-border-radius: 15;" />
                    </VBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Exercises" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleAddExercise" text="+ Add Exercise" style="-fx-background-color: #4f92ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 12 25; -fx-cursor: hand;" />
                    </HBox>
                    <VBox fx:id="exerciseListBox" spacing="10.0" />
                    <Button maxWidth="Infinity" onAction="#handleSave" text="Save Workout" style="-fx-background-color: #4f92ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-padding: 15; -fx-background-radius: 15; -fx-cursor: hand;" />
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>