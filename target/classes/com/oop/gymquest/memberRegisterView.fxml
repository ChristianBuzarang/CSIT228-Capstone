<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" styleClass="root-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.oop.gymquest.MemberRegisterController">
    <children>
        <VBox maxWidth="500.0" spacing="20.0" styleClass="dashboard-card">
            <children>
                <Label styleClass="card-title" text="Member Registration" />
                <Label styleClass="challenge-header" text="Join the Quest: Create New Account" />

                <GridPane hgap="15.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label styleClass="stat-label" text="Full Name" GridPane.rowIndex="0" />
                        <TextField fx:id="nameTextField" promptText="Enter full name" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label styleClass="stat-label" text="Email" GridPane.rowIndex="1" />
                        <TextField fx:id="emailTextField" promptText="example@mail.com" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="stat-label" text="Membership" GridPane.rowIndex="2" />
                        <ComboBox fx:id="comboPlan" prefWidth="350.0" promptText="Select a plan" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label styleClass="stat-label" text="Fitness Goal" GridPane.rowIndex="3" />
                        <TextArea fx:id="goalTextField" prefHeight="80.0" promptText="e.g. Weight loss, Muscle gain" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="action-button, details-button" text="Cancel" />
                        <Button mnemonicParsing="false" onAction="#handleSave" styleClass="action-button, continue-button" text="Save Member" />
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</VBox>