<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<HBox spacing="30" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.DashboardController">

    <VBox spacing="25" HBox.hgrow="ALWAYS">
        <!-- Welcome Card -->
        <HBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 35; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 20, 0, 0, 10);">
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label text="Welcome back, Champion! 🎯" style="-fx-font-size: 28; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
                <Label text="Ready to crush your goals today?" style="-fx-text-fill: #64748b; -fx-font-size: 15;"/>

                <HBox spacing="20" style="-fx-padding: 25 0 0 0;">
                    <VBox prefWidth="220" spacing="8" style="-fx-background-color: #dcf0ff; -fx-padding: 20; -fx-background-radius: 20;">
                        <Label text="Workouts Completed" style="-fx-text-fill: #1e3a8a;"/>
                        <Label text="2" style="-fx-font-size: 32; -fx-font-weight: 900; -fx-text-fill: #3b82f6;"/>
                    </VBox>
                    <VBox prefWidth="220" spacing="8" style="-fx-background-color: #fef9c3; -fx-padding: 20; -fx-background-radius: 20;">
                        <Label text="This Week" style="-fx-text-fill: #854d0e;"/>
                        <Label text="2" style="-fx-font-size: 32; -fx-font-weight: 900; -fx-text-fill: #eab308;"/>
                    </VBox>
                </HBox>
            </VBox>
            <!-- RE-ADDED THE WEIGHTLIFTER LOGO PNG -->
            <ImageView fitHeight="130" preserveRatio="true">
                <Image url="@/com/oop/gymquest/muscle.png"/>
            </ImageView>
        </HBox>

        <!-- Workouts Grid -->
        <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 30;">
            <Label text="Today's Workouts" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
            <GridPane hgap="20" vgap="20">
                <HBox spacing="15" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 20; -fx-border-color: #f1f5f9; -fx-border-width: 1; -fx-border-radius: 20;" GridPane.columnIndex="0">
                    <StackPane style="-fx-background-color: #dcf0ff; -fx-padding: 12; -fx-background-radius: 12;"><ImageView fitHeight="24" fitWidth="24"><Image url="@/com/oop/gymquest/check.png"/></ImageView></StackPane>
                    <VBox spacing="5"><Label text="Full Body Blast" style="-fx-font-weight: bold; -fx-font-size: 16;"/><Label text="Beginner • 30 min" style="-fx-text-fill: #64748b;"/></VBox>
                </HBox>
                <HBox spacing="15" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 20; -fx-border-color: #f1f5f9; -fx-border-width: 1; -fx-border-radius: 20;" GridPane.columnIndex="1">
                    <StackPane style="-fx-background-color: #dcf0ff; -fx-padding: 12; -fx-background-radius: 12;"><ImageView fitHeight="24" fitWidth="24"><Image url="@/com/oop/gymquest/check.png"/></ImageView></StackPane>
                    <VBox spacing="5"><Label text="Upper Body Power" style="-fx-font-weight: bold; -fx-font-size: 16;"/><Label text="Beginner • 25 min" style="-fx-text-fill: #64748b;"/></VBox>
                </HBox>
            </GridPane>
        </VBox>
    </VBox>

    <!-- RIGHT SIDEBAR -->
    <VBox spacing="25" prefWidth="350">
        <!-- Streak Card -->
        <VBox spacing="15" style="-fx-background-color: #f59e0b; -fx-background-radius: 30; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.3), 15, 0, 0, 10);">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 15; -fx-background-radius: 40;"><ImageView fitHeight="30" fitWidth="30"><Image url="@/com/oop/gymquest/muscle.png"/></ImageView></StackPane>
                <VBox><Label text="Current Streak" textFill="white" style="-fx-font-size: 14;"/><Label text="12 days" textFill="white" style="-fx-font-size: 42; -fx-font-weight: 900;"/></VBox>
            </HBox>
        </VBox>

        <!-- Quick Stats: PILL-SHAPED BARS -->
        <VBox spacing="30" style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 35; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 5);">
            <Label text="Quick Stats" style="-fx-font-weight: 800; -fx-font-size: 24; -fx-text-fill: #1e3a5f;"/>

            <VBox spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Weekly Goal" style="-fx-text-fill: #64748b; -fx-font-size: 16;"/><Region HBox.hgrow="ALWAYS" /><Label text="4/5 days" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 18;"/>
                </HBox>
                <StackPane alignment="CENTER_LEFT" prefHeight="16" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20;">
                    <StackPane maxWidth="220" style="-fx-background-color: #3b82f6; -fx-background-radius: 20;" />
                </StackPane>
            </VBox>

            <VBox spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Total Minutes" style="-fx-text-fill: #64748b; -fx-font-size: 16;"/><Region HBox.hgrow="ALWAYS" /><Label text="145 min" style="-fx-text-fill: #d97706; -fx-font-weight: bold; -fx-font-size: 18;"/>
                </HBox>
                <StackPane alignment="CENTER_LEFT" prefHeight="16" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20;">
                    <StackPane maxWidth="180" style="-fx-background-color: #d97706; -fx-background-radius: 20;" />
                </StackPane>
            </VBox>
        </VBox>

        <!-- Motivational Promotion Card -->
        <VBox spacing="15" alignment="CENTER" style="-fx-background-color: #3b82f6; -fx-background-radius: 30; -fx-padding: 40;">
            <ImageView fitHeight="50" fitWidth="50"><Image url="@/com/oop/gymquest/muscle.png"/></ImageView>
            <Label text="Keep it up!" textFill="white" style="-fx-font-weight: 800; -fx-font-size: 24;"/>
            <Label text="You're on fire! Complete one more workout to maintain your streak." textFill="white" wrapText="true" textAlignment="CENTER" style="-fx-font-size: 14; -fx-opacity: 0.9;"/>
        </VBox>
    </VBox>
</HBox>