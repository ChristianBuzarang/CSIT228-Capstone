<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #60a5fa);" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.oop.gymquest.screens.register.RegisterController">

    <VBox alignment="TOP_CENTER" maxWidth="500" spacing="10" style="-fx-background-color: white; -fx-background-radius: 40; -fx-padding: 30 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 30, 0, 0, 15);">

        <ImageView fitHeight="80.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
            <Image url="@gymquest-logo.png" />
        </ImageView>

        <VBox alignment="CENTER" spacing="10">
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="Account Type" />
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="memberBtn" onAction="#selectMember" prefWidth="90" text="Member" />
                <Button fx:id="trainerBtn" onAction="#selectTrainer" prefWidth="90" text="Trainer" />
                <Button fx:id="adminBtn" onAction="#selectAdmin" prefWidth="90" text="Admin" />
            </HBox>

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>
                <children>
                    <VBox spacing="5" GridPane.columnIndex="0">
                        <Label style="-fx-text-fill: #64748b;" text="First Name" />
                        <TextField fx:id="firstnameField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-radius: 10;" />
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1">
                        <Label style="-fx-text-fill: #64748b;" text="Last Name" />
                        <TextField fx:id="lastnameField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-radius: 10;" />
                    </VBox>
                </children>
            <rowConstraints>
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <VBox spacing="5">
                <Label style="-fx-text-fill: #64748b;" text="Email" />
                <TextField fx:id="emailField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-radius: 10;" />
            </VBox>

            <!-- Password Field -->
            <VBox spacing="5">
                <Label style="-fx-text-fill: #64748b;" text="Password" />
                <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #bae6fd; -fx-border-width: 1; -fx-background-color: white;">
                    <StackPane HBox.hgrow="ALWAYS">
                        <PasswordField fx:id="passField" style="-fx-background-color: transparent; -fx-padding: 10;" />
                        <TextField fx:id="passFieldVisible" style="-fx-padding: 10;" visible="false" />
                    </StackPane>
                    <Button onAction="#togglePassword" style="-fx-background-color: transparent;">
                        <graphic><ImageView fx:id="passIcon" fitHeight="18" fitWidth="18"><Image url="@see-password.png" /></ImageView></graphic>
                    </Button>
                </HBox>
            </VBox>

            <!-- Confirm Password Field -->
            <VBox spacing="5">
                <Label style="-fx-text-fill: #64748b;" text="Confirm Password" />
                <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #bae6fd; -fx-border-width: 1; -fx-background-color: white;">
                    <StackPane HBox.hgrow="ALWAYS">
                        <PasswordField fx:id="confirmPassField" style="-fx-background-color: transparent; -fx-padding: 10;" />
                        <TextField fx:id="confirmPassFieldVisible" style="-fx-padding: 10;" visible="false" />
                    </StackPane>
                    <Button onAction="#toggleConfirmPassword" style="-fx-background-color: transparent;">
                        <graphic><ImageView fx:id="confirmIcon" fitHeight="18" fitWidth="18"><Image url="@see-password.png" /></ImageView></graphic>
                    </Button>
                </HBox>
            </VBox>
        </VBox>

        <Button maxWidth="Infinity" onAction="#handleRegister" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-size: 16;" text="Create Account" />

        <Hyperlink onAction="#goToLogin" style="-fx-text-fill: #3b82f6;" text="Already have an account? Sign in" />
        <Label fx:id="statusLabel" textAlignment="CENTER" wrapText="true" />
    </VBox>
</StackPane>
