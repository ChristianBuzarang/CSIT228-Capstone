<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #60a5fa);"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.register.RegisterController">

    <VBox spacing="10" alignment="TOP_CENTER" maxWidth="500"
          style="-fx-background-color: white; -fx-background-radius: 40; -fx-padding: 30 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 30, 0, 0, 15);">

        <ImageView fitHeight="80.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
            <Image url="@gymquest-logo.png" />
        </ImageView>

        <VBox spacing="10" alignment="CENTER">
            <Label text="Account Type" style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="memberBtn" text="Member" onAction="#selectMember" prefWidth="90"/>
                <Button fx:id="trainerBtn" text="Trainer" onAction="#selectTrainer" prefWidth="90"/>
                <Button fx:id="adminBtn" text="Admin" onAction="#selectAdmin" prefWidth="90"/>
            </HBox>

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>
                <children>
                    <VBox spacing="5" GridPane.columnIndex="0">
                        <Label text="First Name" style="-fx-text-fill: #64748b;"/>
                        <TextField fx:id="firstnameField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-radius: 10;"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1">
                        <Label text="Last Name" style="-fx-text-fill: #64748b;"/>
                        <TextField fx:id="lastnameField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-radius: 10;"/>
                    </VBox>
                </children>
            </GridPane>

            <VBox spacing="5">
                <Label text="Email" style="-fx-text-fill: #64748b;"/>
                <TextField fx:id="emailField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-radius: 10;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Username" style="-fx-text-fill: #64748b;"/>
                <TextField fx:id="usernameField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-radius: 10;"/>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="5">
                <Label text="Password" style="-fx-text-fill: #64748b;"/>
                <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-width: 1; -fx-background-color: white;">
                    <StackPane HBox.hgrow="ALWAYS">
                        <PasswordField fx:id="passField" style="-fx-background-color: transparent; -fx-padding: 10;"/>
                        <TextField fx:id="passFieldVisible" visible="false" style="-fx-background-color: transparent; -fx-padding: 10;"/>
                    </StackPane>
                    <Button onAction="#togglePassword" style="-fx-background-color: transparent;">
                        <graphic><ImageView fx:id="passIcon" fitHeight="18" fitWidth="18"><Image url="@see-password.png"/></ImageView></graphic>
                    </Button>
                </HBox>
            </VBox>

            <!-- Confirm Password Field -->
            <VBox spacing="5">
                <Label text="Confirm Password" style="-fx-text-fill: #64748b;"/>
                <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-width: 1; -fx-background-color: white;">
                    <StackPane HBox.hgrow="ALWAYS">
                        <PasswordField fx:id="confirmPassField" style="-fx-background-color: transparent; -fx-padding: 10;"/>
                        <TextField fx:id="confirmPassFieldVisible" visible="false" style="-fx-background-color: transparent; -fx-padding: 10;"/>
                    </StackPane>
                    <Button onAction="#toggleConfirmPassword" style="-fx-background-color: transparent;">
                        <graphic><ImageView fx:id="confirmIcon" fitHeight="18" fitWidth="18"><Image url="@see-password.png"/></ImageView></graphic>
                    </Button>
                </HBox>
            </VBox>
        </VBox>

        <Button text="Create Account" onAction="#handleRegister" maxWidth="Infinity"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-size: 16;"/>

        <Hyperlink text="Already have an account? Sign in" onAction="#goToLogin" style="-fx-text-fill: #3b82f6;"/>
        <Label fx:id="statusLabel" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</StackPane>