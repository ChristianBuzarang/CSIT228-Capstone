<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.sessions.SessionsController" style="-fx-background-color: #f8fafc; -fx-padding: 20;">
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button onAction="#handleBack" text="← Back to Dashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Label text="My Session Records" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
    </HBox>

    <Separator style="-fx-opacity: 0.5;" />

    <!-- Content Area -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <VBox fx:id="allSessionsContainer" spacing="15">
            <!-- Dynamic rows will be injected here -->
            <padding>
                <Insets bottom="20" left="5" right="20" top="5" />
            </padding>
        </VBox>
    </ScrollPane>
</VBox>