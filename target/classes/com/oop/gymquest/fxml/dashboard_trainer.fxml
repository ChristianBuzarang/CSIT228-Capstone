<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oop.gymquest.screens.dashboard.TrainerDashboardController">
    <HBox spacing="20">
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-border-color: #bae6fd; -fx-border-width: 2;">
            <Label text="Today's Sessions" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
            <ListView fx:id="sessionListView" prefHeight="300" style="-fx-background-color: transparent; -fx-border-width: 0;"/>
        </VBox>

        <VBox spacing="15" prefWidth="300">
            <VBox style="-fx-background-color: #10b981; -fx-padding: 20; -fx-background-radius: 15;">
                <Label text="Active Clients" textFill="white"/>
                <Label fx:id="clientCountLabel" text="24" textFill="white" style="-fx-font-size: 32; -fx-font-weight: bold;"/>
            </VBox>
            <Button text="+ Add New Slot" maxWidth="Infinity" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 15; -fx-background-radius: 10; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>
</VBox>