<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="modern-scroll" stylesheets="@../styles.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.TrainerDashboardController">
    <VBox spacing="25" style="-fx-padding: 30;">
        <HBox styleClass="card" alignment="CENTER_LEFT" prefHeight="120">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Trainer Dashboard" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                <Label text="Welcome back, Coach! Here's your overview" styleClass="subtitle-gray"/>
            </VBox>
            <Label text="😊" style="-fx-font-size: 60;"/>
        </HBox>

        <HBox spacing="20">
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #dcf0ff; -fx-padding: 20; -fx-background-radius: 20;">
                <Label text="👤 Total Clients" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold;"/><Label fx:id="clientCountLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: 900; -fx-text-fill: #3b82f6;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #fef9c3; -fx-padding: 20; -fx-background-radius: 20;">
                <Label text="📅 Today's Sessions" style="-fx-text-fill: #ca8a04; -fx-font-weight: bold;"/><Label fx:id="totalSlotsLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: 900; -fx-text-fill: #ca8a04;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #dcfce7; -fx-padding: 20; -fx-background-radius: 20;">
                <Label text="🏋️ Booked Today" style="-fx-text-fill: #16a34a; -fx-font-weight: bold;"/><Label fx:id="bookedSlotsLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: 900; -fx-text-fill: #16a34a;"/>
            </VBox>
        </HBox>

        <HBox spacing="30">
            <VBox spacing="20" HBox.hgrow="ALWAYS" styleClass="card" minWidth="600"><Label text="Today's Schedule" styleClass="heading-text"/><VBox fx:id="scheduleContainer" spacing="15"/></VBox>
            <VBox spacing="20" prefWidth="400" styleClass="card"><Label text="My Clients" styleClass="heading-text"/><VBox fx:id="clientContainer" spacing="15"/></VBox>
        </HBox>
    </VBox>
</ScrollPane>