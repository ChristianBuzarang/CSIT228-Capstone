<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" maxWidth="500" spacing="15"
      style="-fx-background-color: #3b82f6; -fx-background-radius: 40; -fx-padding: 40 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 30, 0, 0, 15);"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oop.gymquest.screens.register.RegisterAdminController">

    <!-- Header Title -->
    <Label text="New Admin Account"
           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 10 0;"/>

    <VBox spacing="12">
        <GridPane hgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <children>
                <VBox spacing="5" GridPane.columnIndex="0">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="First Name" />
                    <TextField fx:id="firstnameField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-background-color: white;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Last Name" />
                    <TextField fx:id="lastnameField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-background-color: white;" />
                </VBox>
            </children>
        </GridPane>

        <VBox spacing="5">
            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Email" />
            <TextField fx:id="emailField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-background-color: white;" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Admin Password" />
            <PasswordField fx:id="passField" style="-fx-padding: 10; -fx-background-radius: 10; -fx-background-color: white;" />
        </VBox>
    </VBox>

    <VBox spacing="10" style="-fx-padding: 15 0 0 0;">
        <!-- Primary Button: White background with blue text -->
        <Button maxWidth="Infinity" onAction="#handleCreateAdmin" text="Create Admin Account"
                style="-fx-background-color: white; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-size: 15;" />

        <!-- Cancel Button: Transparent with white text -->
        <Button maxWidth="Infinity" onAction="#handleCancel" text="Cancel"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
    </VBox>

    <Label fx:id="statusLabel" textAlignment="CENTER" wrapText="true" style="-fx-text-fill: white;" />
</VBox>