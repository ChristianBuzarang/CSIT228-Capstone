<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="350"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-border-width: 1;"
      xmlns:fx="http://javafx.com/fxml/1">

    <Label text="Notifications" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-padding: 15; -fx-text-fill: #1e293b;"/>

    <Separator style="-fx-opacity: 0.5;"/>

    <!-- This is where the notification_item.fxml rows will be loaded -->
    <VBox fx:id="notificationList" maxHeight="400">
        <!-- Placeholder for empty state -->
        <Label text="No new notifications" style="-fx-text-fill: #94a3b8; -fx-padding: 20;"/>
    </VBox>

    <Button text="Mark all as read" maxWidth="Infinity"
            style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-padding: 12; -fx-cursor: hand; -fx-font-size: 12;"/>
</VBox>