<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.*?>

<VBox spacing="25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.AdminDashboardController">

    <!-- STATS OVERVIEW ROW -->
    <HBox spacing="15" alignment="CENTER">
        <!-- Total Members Card -->
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #3b82f6; -fx-border-width: 0 0 0 5;">
            <Label text="Total Members" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="totalMembersLabel" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="+12% from last month" style="-fx-text-fill: #10b981; -fx-font-size: 11;"/>
        </VBox>

        <!-- Active Members Card (THIS WAS MISSING) -->
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #10b981; -fx-border-width: 0 0 0 5;">
            <Label text="Active Members" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="activeMembersLabel" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Currently in gym" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
        </VBox>

        <!-- Total Trainers Card -->
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #f59e0b; -fx-border-width: 0 0 0 5;">
            <Label text="Total Trainers" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="totalTrainersLabel" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="On-call staff" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
        </VBox>

        <!-- Active Trainers Card -->
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #ef4444; -fx-border-width: 0 0 0 5;">
            <Label text="Active Sessions" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="activeTrainersLabel" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Ongoing training" style="-fx-text-fill: #f59e0b; -fx-font-size: 11;"/>
        </VBox>
    </HBox>

    <!-- USER MANAGEMENT AREA -->
    <VBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="User Management" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Manage active accounts or archive them to cold storage." style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="10">
                <Button text="+ Create Admin" onAction="#handleCreateAdmin"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
                <Button text="Refresh List" onAction="#refreshUserTable"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
            </HBox>
        </HBox>

        <!-- Toggle Row for Roles -->
        <HBox spacing="10">
            <Button fx:id="btnToggleMembers" text="Members" onAction="#showMembers" style="-fx-background-color: #eff6ff; -fx-text-fill: #3b82f6; -fx-background-radius: 10; -fx-padding: 8 20; -fx-font-weight: bold;"/>
            <Button fx:id="btnToggleTrainers" text="Trainers" onAction="#showTrainers" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-padding: 8 20;"/>
            <Button fx:id="btnToggleAdmins" text="Admins" onAction="#showAdmins" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-padding: 8 20;"/>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="🔍 Search user..." style="-fx-background-radius: 10; -fx-pref-width: 250;"/>
        </HBox>

        <TableView fx:id="userTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #f1f5f9; -fx-border-radius: 10;">
            <columns>
                <TableColumn text="ID" prefWidth="60">
                    <cellValueFactory><PropertyValueFactory property="userId"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Full Name" prefWidth="180">
                    <cellValueFactory><PropertyValueFactory property="fullName"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Email" prefWidth="200">
                    <cellValueFactory><PropertyValueFactory property="email"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Role" prefWidth="120">
                    <cellValueFactory><PropertyValueFactory property="type"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="Edit User" onAction="#handleEditUser" style="-fx-background-color: #eff6ff; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
            <Button text="Archive User" onAction="#handleDeleteUser" style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
        </HBox>
    </VBox>
</VBox>