<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.DashboardController" style="-fx-background-color: #f8fafc;">

    <!-- TOP HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 10 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
            <ImageView fitHeight="35" preserveRatio="true">
                <Image url="@../images/gymquest-logo.png"/>
            </ImageView>

            <Region HBox.hgrow="ALWAYS" />

            <HBox spacing="20" alignment="CENTER">
                <!-- NOTIFICATION WITH BADGE -->
                <StackPane>
                    <Button fx:id="notificationBell" onAction="#handleShowNotifications" style="-fx-background-color: transparent; -fx-cursor: hand;">
                        <graphic><ImageView fitHeight="24" fitWidth="24"><Image url="@../images/notification.png"/></ImageView></graphic>
                    </Button>
                    <Label text="2" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 2 6; -fx-background-radius: 10;" StackPane.alignment="TOP_RIGHT">
                        <StackPane.margin><Insets right="5" top="5"/></StackPane.margin>
                    </Label>
                </StackPane>

                <HBox spacing="10" alignment="CENTER">
                    <Label fx:id="headerNameLabel" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 15;"/>
                    <!-- Avatar: Blue circle with User Icon -->
                    <StackPane style="-fx-background-color: #3b82f6; -fx-background-radius: 25; -fx-min-width: 42; -fx-min-height: 42;">
                        <ImageView fitHeight="20" fitWidth="20"><Image url="@../images/user.png"/></ImageView>
                    </StackPane>
                </HBox>

                <Label fx:id="headerTypeLabel" visible="false" managed="false"/>
                <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #3b82f6; -fx-border-color: #bae6fd; -fx-border-radius: 10; -fx-padding: 8 18; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR WITH ICON BUTTONS -->
    <left>
        <VBox spacing="10" prefWidth="260" style="-fx-background-color: white; -fx-padding: 30 20; -fx-border-color: #f1f5f9; -fx-border-width: 0 1 0 0;">
            <Button maxWidth="Infinity" style="-fx-background-color: #eff6ff; -fx-text-fill: #3b82f6; -fx-alignment: CENTER_LEFT; -fx-padding: 15; -fx-background-radius: 15; -fx-font-weight: bold; -fx-cursor: hand;">
                <graphic><ImageView fitHeight="20" fitWidth="20"><Image url="@../images/home.png"/></ImageView></graphic>
                <text>  Dashboard</text>
            </Button>
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-alignment: CENTER_LEFT; -fx-padding: 15; -fx-cursor: hand;">
                <graphic><ImageView fitHeight="20" fitWidth="20"><Image url="@../images/muscle.png"/></ImageView></graphic>
                <text>  Workouts</text>
            </Button>
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-alignment: CENTER_LEFT; -fx-padding: 15; -fx-cursor: hand;">
                <graphic><ImageView fitHeight="20" fitWidth="20"><Image url="@../images/book-session.png"/></ImageView></graphic>
                <text>  Book Trainer</text>
            </Button>
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-alignment: CENTER_LEFT; -fx-padding: 15; -fx-cursor: hand;">
                <graphic><ImageView fitHeight="20" fitWidth="20"><Image url="@../images/group.png"/></ImageView></graphic>
                <text>  Community</text>
            </Button>
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-alignment: CENTER_LEFT; -fx-padding: 15; -fx-cursor: hand;">
                <graphic><ImageView fitHeight="20" fitWidth="20"><Image url="@../images/profile.png"/></ImageView></graphic>
                <text>  Profile</text>
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 30;" />
    </center>
</BorderPane>