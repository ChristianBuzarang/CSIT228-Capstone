<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Ensure fx:controller points to the NEW class created in Step 1 -->
<HBox spacing="15" alignment="CENTER_LEFT" prefWidth="340"
      fx:controller="com.oop.gymquest.screens.notifications.NotificationItemController"
      style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 12;"
      xmlns:fx="http://javafx.com/fxml/1">

    <StackPane style="-fx-background-color: #eff6ff; -fx-background-radius: 10; -fx-min-width: 40; -fx-min-height: 40;">
        <Label fx:id="iconLabel" text="🔔" style="-fx-font-size: 18;"/>
    </StackPane>

    <VBox spacing="2" HBox.hgrow="ALWAYS">
        <Label fx:id="msgLabel" text="Title" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
        <Label fx:id="timeLabel" text="Time" style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
    </VBox>
</HBox>