<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<VBox spacing="30" style="-fx-background-color: #f8fafc;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.MemberDashboardController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <HBox spacing="30" alignment="TOP_CENTER">
        <HBox alignment="CENTER_LEFT" spacing="20" HBox.hgrow="ALWAYS" prefHeight="220"
              style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 35;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 20, 0, 0, 8);">

            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <VBox spacing="5">
                    <Label text="Welcome back, Champion! 🎯"
                           style="-fx-font-size: 28; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
                    <Label text="Ready to crush your goals today?"
                           style="-fx-text-fill: #64748b; -fx-font-size: 16;"/>
                </VBox>
            </VBox>

            <ImageView fitHeight="140" preserveRatio="true">
                <Image url="@../images/muscle.png"/>
            </ImageView>
        </HBox>

        <VBox spacing="20" alignment="CENTER" prefWidth="380" minWidth="380" prefHeight="220"
              style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb);
                     -fx-background-radius: 28; -fx-padding: 30;
                     -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.3), 20, 0, 0, 10);">

            <ImageView fitHeight="50" fitWidth="50" preserveRatio="true">
                <Image url="@../images/muscle.png"/>
            </ImageView>
            <VBox spacing="5" alignment="CENTER">
                <Label text="Keep it up!"
                       style="-fx-font-weight: 800; -fx-font-size: 24; -fx-text-fill: white;"/>
                <Label text="Complete one more workout to maintain your streak."
                       wrapText="true" textAlignment="CENTER"
                       style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.9);"/>
            </VBox>
        </VBox>
    </HBox>

    <!-- Upcoming Sessions + Recent Activity -->
    <HBox spacing="30" VBox.vgrow="ALWAYS">

        <!-- Left: Upcoming Sessions -->
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <Label text="Upcoming Sessions"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <VBox fx:id="activeSessionsContainer" spacing="15">
                <!-- Dynamic Cards -->
            </VBox>
        </VBox>

        <!-- Right: Recent Activity -->
        <VBox spacing="15" prefWidth="380" minWidth="380">
            <HBox alignment="CENTER_LEFT">
                <Label text="Recent Activity"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Hyperlink text="See All" onAction="#handleSeeAll"
                           style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-underline: false;"/>
            </HBox>
            <VBox fx:id="historySessionsContainer" spacing="15">
                <!-- Dynamic Cards -->
            </VBox>
        </VBox>
    </HBox>

</VBox>