<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<HBox spacing="30" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.MemberDashboardController">
    <VBox spacing="25" HBox.hgrow="ALWAYS">
        <!-- Welcome Card -->
        <HBox spacing="20" styleClass="card">
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label text="Welcome back, Champion! 🎯" style="-fx-font-size: 28; -fx-font-weight: 800; -fx-text-fill: black;"/>
                <Label text="Ready to crush your goals today?" style="-fx-text-fill: #64748b; -fx-font-size: 15;"/>
                <HBox spacing="20" style="-fx-padding: 25 0 0 0;">
                    <VBox prefWidth="220" spacing="8" style="-fx-background-color: #dcf0ff; -fx-padding: 20; -fx-background-radius: 20;">
                        <Label text="Workouts Completed" style="-fx-text-fill: #1e3a8a;"/><Label text="2" style="-fx-font-size: 32; -fx-font-weight: 900; -fx-text-fill: #3b82f6;"/>
                    </VBox>
                    <VBox prefWidth="220" spacing="8" style="-fx-background-color: #fef9c3; -fx-padding: 20; -fx-background-radius: 20;">
                        <Label text="This Week" style="-fx-text-fill: #854d0e;"/><Label text="2" style="-fx-font-size: 32; -fx-font-weight: 900; -fx-text-fill: #eab308;"/>
                    </VBox>
                </HBox>
            </VBox>
            <ImageView fitHeight="130" preserveRatio="true"><Image url="@../images/muscle.png"/></ImageView>
        </HBox>

        <!-- Your Sessions Today -->
        <VBox fx:id="sessionsTodayContainer" spacing="12">
            <Label text="Your Sessions Today" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <GridPane hgap="20" vgap="20">
                <HBox spacing="15" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 20; -fx-border-color: #f1f5f9; -fx-border-width: 1; -fx-border-radius: 20;" GridPane.columnIndex="0">
                    <StackPane style="-fx-background-color: #dcf0ff; -fx-padding: 12; -fx-background-radius: 12;"><ImageView fitHeight="24" fitWidth="24"><Image url="@../images/check.png"/></ImageView></StackPane>
                    <VBox spacing="5"><Label text="Full Body Blast" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: black;"/><Label text="Beginner • 30 min" style="-fx-text-fill: #64748b;"/></VBox>
                </HBox>
            </GridPane>
        </VBox>
    </VBox>

    <VBox spacing="25" prefWidth="350">
        <!-- Quick Stats -->
        <VBox spacing="30" styleClass="card">
            <Label text="Quick Stats" style="-fx-font-weight: 800; -fx-font-size: 24; -fx-text-fill: black;"/>
            <VBox spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Weekly Goal" style="-fx-text-fill: #64748b; -fx-font-size: 16;"/><Region HBox.hgrow="ALWAYS" /><Label text="4/5 days" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 18;"/>
                </HBox>
                <StackPane alignment="CENTER_LEFT" prefHeight="16" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20;">
                    <StackPane maxWidth="220" style="-fx-background-color: #3b82f6; -fx-background-radius: 20;" />
                </StackPane>
            </VBox>
            <VBox spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Total Minutes" style="-fx-text-fill: #64748b; -fx-font-size: 16;"/><Region HBox.hgrow="ALWAYS" /><Label text="145 min" style="-fx-text-fill: #d97706; -fx-font-weight: bold; -fx-font-size: 18;"/>
                </HBox>
                <StackPane alignment="CENTER_LEFT" prefHeight="16" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20;">
                    <StackPane maxWidth="180" style="-fx-background-color: #d97706; -fx-background-radius: 20;" />
                </StackPane>
            </VBox>
        </VBox>

        <!-- FIX: Blue Card with White Text -->
        <VBox spacing="15" alignment="CENTER" style="-fx-background-color: #3b82f6; -fx-background-radius: 30; -fx-padding: 40;">
            <ImageView fitHeight="50" fitWidth="50"><Image url="@../images/muscle.png"/></ImageView>
            <Label text="Keep it up!" style="-fx-font-weight: 800; -fx-font-size: 24; -fx-text-fill: white;"/>
            <Label text="You're on fire! Complete one more workout to maintain your streak." wrapText="true" textAlignment="CENTER" style="-fx-font-size: 14; -fx-text-fill: white;"/>
        </VBox>
    </VBox>
</HBox>