<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" stylesheets="@../styles.css" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oop.gymquest.screens.manageSchedule.ManageScheduleController">
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <HBox styleClass="card" alignment="CENTER_LEFT" prefHeight="100">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Manage Schedule" styleClass="title"/>
            <Label text="Create and manage your training sessions" styleClass="subtitle-gray"/>
        </VBox>
        <Button text="+ Add Schedule" onAction="#handleAddSchedule" styleClass="btn-primary"/>
    </HBox>

    <VBox spacing="20" VBox.vgrow="ALWAYS" styleClass="card">
        <Label fx:id="countLabel" text="Your Schedules (0)" styleClass="heading-text"/>
        <ScrollPane fitToWidth="true" styleClass="modern-scroll" VBox.vgrow="ALWAYS">
            <StackPane>
                <VBox fx:id="emptyPlaceholder" alignment="CENTER" spacing="20" visible="false">
                    <ImageView fitHeight="100" preserveRatio="true"><Image url="@../images/calendar.png"/></ImageView>
                    <Label text="No schedules created yet" styleClass="subtitle-gray"/>
                    <Button text="Create Your First Schedule" onAction="#handleAddSchedule" styleClass="btn-primary" />
                </VBox>
                <VBox fx:id="scheduleList" spacing="12" />
            </StackPane>
        </ScrollPane>
    </VBox>
</VBox>