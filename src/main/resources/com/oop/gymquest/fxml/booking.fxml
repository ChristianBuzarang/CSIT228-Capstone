<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>

<VBox spacing="20" styleClass="main-container" stylesheets="@../styles.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.booking.BookingController">
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <HBox styleClass="card" alignment="CENTER_LEFT" prefHeight="100">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Book a Training Session" styleClass="title"/>
            <Label text="Select a date to see available trainers and time slots" styleClass="subtitle-gray"/>
        </VBox>
        <ImageView fitHeight="50" fitWidth="50" pickOnBounds="true" preserveRatio="true">
            <Image url="@../images/calendar.png"/>
        </ImageView>
    </HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">
        <VBox spacing="20" prefWidth="400" styleClass="card" alignment="TOP_CENTER">
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="monthLabel" styleClass="month-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="10">
                    <Button text="‹" onAction="#onPrevMonth" styleClass="nav-btn-round"/>
                    <Button text="›" onAction="#onNextMonth" styleClass="nav-btn-round"/>
                </HBox>
            </HBox>
            <HBox spacing="5" alignment="CENTER">
                <Label text="Sun" styleClass="day-header"/><Label text="Mon" styleClass="day-header"/><Label text="Tue" styleClass="day-header"/><Label text="Wed" styleClass="day-header"/><Label text="Thu" styleClass="day-header"/><Label text="Fri" styleClass="day-header"/><Label text="Sat" styleClass="day-header"/>
            </HBox>
            <GridPane fx:id="calendarGrid" hgap="5" vgap="5" alignment="CENTER" />
        </VBox>

        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" styleClass="modern-scroll">
            <VBox fx:id="trainerPanel" spacing="15"/>
        </ScrollPane>
    </HBox>
</VBox>