<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.*?>
<?import java.net.URL?>

<VBox spacing="25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.AdminDashboardController" styleClass="main-container">
    <stylesheets>
        <URL value="@../styles.css" />
    </stylesheets>

    <HBox spacing="15" alignment="CENTER">
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #3b82f6; -fx-border-width: 0 0 0 5;">
            <Label text="Total Members" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="totalMembersLabel" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #f59e0b; -fx-border-width: 0 0 0 5;">
            <Label text="Total Trainers" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="totalTrainersLabel" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="On-call staff" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
        </VBox>
    </HBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS" styleClass="card">
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="User Management" styleClass="heading-text"/>
                <Label text="Manage active accounts or archive them to cold storage." styleClass="subtitle-gray"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="10">
                <Button text="+ Create Account" onAction="#handleCreateAdmin" styleClass="btn-primary" focusTraversable="false"/>
                <Button text="Export Summary" onAction="#handleExportSummary" styleClass="btn-export-summary"/>
            </HBox>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <HBox styleClass="toggle-nav-container">
                <Button fx:id="btnToggleMembers" text="Members" onAction="#showMembers" styleClass="toggle-nav-btn" focusTraversable="false"/>
                <Button fx:id="btnToggleTrainers" text="Trainers" onAction="#showTrainers" styleClass="toggle-nav-btn" focusTraversable="false"/>
                <Button fx:id="btnToggleAdmins" text="Admins" onAction="#showAdmins" styleClass="toggle-nav-btn" focusTraversable="false"/>
                <Button fx:id="btnToggleArchive" text="Archive" onAction="#showArchive" styleClass="toggle-nav-btn" focusTraversable="false"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="🔍 Search user by name or email..." styleClass="search-field" prefWidth="350" focusTraversable="false"/>
        </HBox>

        <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <placeholder>
                <Label text="No content in table" styleClass="placeholder-label"/>
            </placeholder>
            <columns>
                <TableColumn text="ID" prefWidth="60" reorderable="false">
                    <cellValueFactory><PropertyValueFactory property="userId"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Full Name" prefWidth="200" reorderable="false">
                    <cellValueFactory><PropertyValueFactory property="fullName"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Email" prefWidth="250" reorderable="false">
                    <cellValueFactory><PropertyValueFactory property="email"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Role" prefWidth="120" reorderable="false">
                    <cellValueFactory><PropertyValueFactory property="type"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="actionsCol" text="Actions" prefWidth="280" sortable="false" reorderable="false" style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>