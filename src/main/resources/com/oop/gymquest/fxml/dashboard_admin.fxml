<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.*?>

<VBox spacing="25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.AdminDashboardController">

    <!-- STATS OVERVIEW ROW -->
    <HBox spacing="20" alignment="CENTER">
        <!-- Total Members Card -->
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #e0f2fe; -fx-border-width: 0 0 0 5;">
            <Label text="Total Members" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="totalMembersLabel" text="1,284" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="+12% from last month" style="-fx-text-fill: #10b981; -fx-font-size: 11;"/>
        </VBox>

        <!-- Active Trainers Card -->
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #fef3c7; -fx-border-width: 0 0 0 5;">
            <Label text="Active Trainers" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="activeTrainersLabel" text="42" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="3 currently on session" style="-fx-text-fill: #f59e0b; -fx-font-size: 11;"/>
        </VBox>

        <!-- System Status Card -->
        <VBox HBox.hgrow="ALWAYS" spacing="5" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #d1fae5; -fx-border-width: 0 0 0 5;">
            <Label text="Database Status" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label text="ONLINE" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
            <Label text="Last sync: Just now" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
        </VBox>
    </HBox>

    <!-- USER MANAGEMENT AREA -->
    <VBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="User Management" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Manage active accounts or archive them to cold storage." style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="10">
                <!-- New Admin Button -->
                <Button text="+ Create Admin" onAction="#handleCreateAdmin"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
                <Button text="Refresh List" onAction="#refreshUserTable"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15;"/>
            </HBox>
        </HBox>

        <TableView fx:id="userTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #f1f5f9; -fx-border-radius: 10;">
            <columns>
                <TableColumn text="ID" prefWidth="60">
                    <cellValueFactory><PropertyValueFactory property="userId"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Full Name" prefWidth="180">
                    <cellValueFactory><PropertyValueFactory property="fullName"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Email" prefWidth="200">
                    <cellValueFactory><PropertyValueFactory property="email"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Role" prefWidth="120">
                    <cellValueFactory><PropertyValueFactory property="type"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="Edit User" style="-fx-background-color: #eff6ff; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
            <Button text="Delete User" onAction="#handleDeleteUser" style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
        </HBox>
    </VBox>
</VBox>