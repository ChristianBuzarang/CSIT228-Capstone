<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="15" alignment="CENTER_LEFT" prefWidth="340"
      fx:controller="com.oop.gymquest.screens.notifications.NotificationItemController"
      style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 12;"
      xmlns:fx="http://javafx.com/fxml/1">

    <StackPane style="-fx-background-color: #eff6ff; -fx-background-radius: 10; -fx-min-width: 40; -fx-min-height: 40;">
        <Label fx:id="iconLabel" text="🔔" style="-fx-font-size: 18; -fx-text-fill: #3b82f6;"/>
    </StackPane>

    <VBox spacing="2" HBox.hgrow="ALWAYS">
        <Label fx:id="msgLabel" text="Notification Title" wrapText="true" style="-fx-font-size: 13; -fx-text-fill: #1e293b; -fx-font-weight: bold;"/>
        <Label fx:id="timeLabel" text="2 hours ago" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
    </VBox>
</HBox>