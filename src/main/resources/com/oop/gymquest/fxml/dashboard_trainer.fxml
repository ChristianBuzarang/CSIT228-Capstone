<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25" stylesheets="@../styles.css" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.TrainerDashboardController">

    <!-- Top Header -->
    <HBox styleClass="card" alignment="CENTER_LEFT" prefHeight="100">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Trainer Dashboard" styleClass="title"/>
            <Label text="Manage your schedule and track active clients" styleClass="subtitle-gray"/>
        </VBox>
        <Button text="+ Add New Slot" onAction="#handleAddSlot" styleClass="btn-primary"/>
    </HBox>

    <!-- Stats summary -->
    <HBox spacing="15">
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #e0f2fe; -fx-padding: 20; -fx-background-radius: 15;">
            <Label text="Total Slots" styleClass="subtitle-gray"/><Label fx:id="totalSlotsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #fef3c7; -fx-padding: 20; -fx-background-radius: 15;">
            <Label text="Booked" styleClass="subtitle-gray"/><Label fx:id="bookedSlotsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #d97706;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #dcfce7; -fx-padding: 20; -fx-background-radius: 15;">
            <Label text="Available" styleClass="subtitle-gray"/><Label fx:id="availableSlotsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #e0f2fe; -fx-padding: 20; -fx-background-radius: 15;">
            <Label text="Clients" styleClass="subtitle-gray"/><Label fx:id="clientCountLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
        </VBox>
    </HBox>

    <!-- Scrollable schedule list -->
    <VBox spacing="15" VBox.vgrow="ALWAYS" styleClass="card">
        <Label text="Your Schedule" styleClass="heading-text"/>
        <ScrollPane fitToWidth="true" styleClass="modern-scroll" VBox.vgrow="ALWAYS">
            <VBox fx:id="scheduleContainer" spacing="10" />
        </ScrollPane>
    </VBox>
</VBox>