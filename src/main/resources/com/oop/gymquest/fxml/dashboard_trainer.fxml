<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" styleClass="modern-scroll" stylesheets="@../styles.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.TrainerDashboardController">
    <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #f8fafc;">

        <!-- Welcome Header Card -->
        <HBox styleClass="card" alignment="CENTER_LEFT" prefHeight="120" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Trainer Dashboard" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                <Label text="Welcome back, Coach! Here's your overview" style="-fx-text-fill: #64748b; -fx-font-size: 14;"/>
            </VBox>
            <Label text="😊" style="-fx-font-size: 60;"/>
        </HBox>

        <!-- Stats Row -->
        <HBox spacing="20">
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #dcf0ff; -fx-padding: 20; -fx-background-radius: 20;">
                <Label text="👤 Total Clients" style="-fx-text-fill: #1e3a8a; -fx-font-weight: bold;"/>
                <Label fx:id="clientCountLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: 900; -fx-text-fill: #3b82f6;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #fef9c3; -fx-padding: 20; -fx-background-radius: 20;">
                <Label text="📅 Today's Sessions" style="-fx-text-fill: #854d0e; -fx-font-weight: bold;"/>
                <Label fx:id="totalSlotsLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: 900; -fx-text-fill: #eab308;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #dcfce7; -fx-padding: 20; -fx-background-radius: 20;">
                <Label text="🏋️ Booked Today" style="-fx-text-fill: #166534; -fx-font-weight: bold;"/>
                <Label fx:id="bookedSlotsLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: 900; -fx-text-fill: #16a34a;"/>
            </VBox>
        </HBox>

        <!-- Main Content Grid -->
        <HBox spacing="30">

            <!-- Schedule Section -->
            <VBox spacing="20" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" minWidth="600">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Today's Schedule" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <!-- Requirement: See All for Schedules -->
                    <Hyperlink text="See All Sessions" onAction="#handleSeeAllSchedules"
                               style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-underline: false; -fx-font-size: 13;"/>
                </HBox>
                <VBox fx:id="scheduleContainer" spacing="15"/>
            </VBox>

            <!-- Client Section -->
            <VBox spacing="20" prefWidth="400" styleClass="card" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT">
                    <Label text="My Clients" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <!-- Requirement: See All for Clients -->
                    <Hyperlink text="View Directory" onAction="#handleSeeAllClients"
                               style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-underline: false; -fx-font-size: 13;"/>
                </HBox>
                <VBox fx:id="clientContainer" spacing="15"/>
            </VBox>

        </HBox>
    </VBox>
</ScrollPane>