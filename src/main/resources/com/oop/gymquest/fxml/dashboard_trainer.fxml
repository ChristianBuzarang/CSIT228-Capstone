<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<ScrollPane fitToWidth="true" styleClass="modern-scroll" stylesheets="@../styles.css"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oop.gymquest.screens.dashboard.userdashboards.TrainerDashboardController">

    <VBox spacing="30" style="-fx-padding: 30; -fx-background-color: #f8fafc;">
        <HBox alignment="CENTER_LEFT" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 20, 0, 0, 8);">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Trainer Dashboard"
                       style="-fx-font-size: 30; -fx-font-weight: 800; -fx-text-fill: #1e3a5f;"/>
                <Label text="Welcome back, Coach! Here's your overview for today."
                       style="-fx-text-fill: #64748b; -fx-font-size: 15;"/>
            </VBox>
            <ImageView fitHeight="80" preserveRatio="true">
                <Image url="@../images/muscle.png"/>
            </ImageView>
        </HBox>

        <HBox spacing="30" VBox.vgrow="ALWAYS">
            <VBox spacing="25" HBox.hgrow="ALWAYS">
                <VBox style="-fx-background-color: #fef9c3; -fx-padding: 25; -fx-background-radius: 20;
                             -fx-effect: dropshadow(gaussian, rgba(234,179,8,0.1), 15, 0, 0, 5);">
                    <Label text="📅 Total Sessions" style="-fx-text-fill: #854d0e; -fx-font-weight: bold; -fx-font-size: 14;"/>
                    <Label fx:id="totalSlotsLabel" text="0"
                           style="-fx-font-size: 42; -fx-font-weight: 900; -fx-text-fill: #ca8a04;"/>
                </VBox>

                <!-- My Sessions Content -->
                <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 24;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 20, 0, 0, 8);" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="My Sessions" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink text="See All" onAction="#handleSeeAllSchedules"
                                   style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-underline: false; -fx-font-size: 14;"/>
                    </HBox>
                    <VBox fx:id="scheduleContainer" spacing="15"/>
                </VBox>
            </VBox>

            <VBox spacing="25" prefWidth="420" minWidth="420">
                <VBox style="-fx-background-color: #dcf0ff; -fx-padding: 25; -fx-background-radius: 20;
                             -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.1), 15, 0, 0, 5);">
                    <Label text="👤 Total Clients" style="-fx-text-fill: #1e3a8a; -fx-font-weight: bold; -fx-font-size: 14;"/>
                    <Label fx:id="clientCountLabel" text="0"
                           style="-fx-font-size: 42; -fx-font-weight: 900; -fx-text-fill: #3b82f6;"/>
                </VBox>

                <!-- My Clients Content -->
                <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 24;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 20, 0, 0, 8);" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="My Clients" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink text="See All" onAction="#handleSeeAllClients"
                                   style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-underline: false; -fx-font-size: 14;"/>
                    </HBox>
                    <VBox fx:id="clientContainer" spacing="15"/>
                </VBox>
            </VBox>

        </HBox>
    </VBox>
</ScrollPane>