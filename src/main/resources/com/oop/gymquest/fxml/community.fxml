<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" styleClass="main-container" stylesheets="@../styles.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.community.CommunityController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>
    <HBox styleClass="card" alignment="CENTER_LEFT" prefHeight="100">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Community Feed" styleClass="title" style="-fx-text-fill: #1e3a5f;"/>
            <Label text="Celebrate achievements together!" styleClass="subtitle-gray"/>
        </VBox>
        <HBox spacing="15" alignment="CENTER">
            <Button text="+ Share Milestone" onAction="#handleShareMilestone" styleClass="btn-primary"/>
            <ImageView fitHeight="50" preserveRatio="true"><Image url="@../images/group.png"/></ImageView>
        </HBox>
    </HBox>
    <ScrollPane fitToWidth="true" styleClass="modern-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="postContainer" spacing="20" />
    </ScrollPane>
</VBox>