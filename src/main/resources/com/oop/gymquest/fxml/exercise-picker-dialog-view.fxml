<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="750.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.exercisePicker.ExercisePickerDialogController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
    <TextField fx:id="searchField" promptText="🔍 Search exercises..." style="-fx-background-radius: 15; -fx-border-color: #bae6fd; -fx-padding: 12;" />
    <HBox spacing="10.0">
        <children>
            <ToggleButton fx:id="allToggle" selected="true" text="All" style="-fx-background-radius: 10; -fx-padding: 8 20;" userData="all">
                <toggleGroup><ToggleGroup fx:id="categoryGroup" /></toggleGroup>
            </ToggleButton>
            <ToggleButton text="Strength" toggleGroup="$categoryGroup" userData="strength" style="-fx-background-radius: 10; -fx-padding: 8 20;" />
            <ToggleButton text="Cardio" toggleGroup="$categoryGroup" userData="cardio" style="-fx-background-radius: 10; -fx-padding: 8 20;" />
        </children>
    </HBox>
    <ScrollPane fitToWidth="true" prefHeight="400.0" style="-fx-background-color: transparent; -fx-background: transparent;">
        <content><FlowPane fx:id="exerciseGrid" hgap="15.0" vgap="15.0" /></content>
    </ScrollPane>
</VBox>