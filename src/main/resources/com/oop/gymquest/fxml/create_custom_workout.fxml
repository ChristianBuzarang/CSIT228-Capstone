<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>


<ScrollPane fitToWidth="true"
            style="-fx-background-color: #f0f8ff; -fx-background: #f0f8ff;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oop.gymquest.screens.customWorkoutCreator.CustomWorkoutCreatorController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="20.0">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

            <!-- Back button -->
            <HBox maxWidth="620.0">
                <Button onAction="#handleBack"
                        text="←  Back to Workouts"
                        style="-fx-background-color: transparent; -fx-text-fill: #3b82f6;
                               -fx-cursor: hand; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- ══ FORM CARD ═══════════════════════════════════════════════ -->
            <VBox maxWidth="620.0" spacing="22.0"
                  style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 38;">
                <effect><DropShadow blurType="GAUSSIAN" color="rgba(0,0,0,0.07)" radius="20" offsetY="4"/></effect>

                <Label text="Create Custom Workout"
                       style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #1e3a5f;"/>

                <!-- ── Workout Name ───────────────────────────────────── -->
                <VBox spacing="8.0">
                    <Label text="Workout Name"
                           style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 13px;"/>
                    <TextField fx:id="nameField"
                               promptText="My Awesome Workout"
                               style="-fx-padding: 14; -fx-border-color: #bae6fd; -fx-border-width: 2;
                                      -fx-background-radius: 14; -fx-border-radius: 14; -fx-font-size: 14px;"/>
                </VBox>


                <VBox spacing="8.0">
                    <Label text="Workout Category"
                           style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 13px;"/>
                    <Label text="Tag your workout so it appears in the right filter."
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="categoryPicker"
                              maxWidth="Infinity"
                              style="-fx-padding: 8 12; -fx-border-color: #bae6fd; -fx-border-width: 2;
                                     -fx-background-radius: 14; -fx-border-radius: 14;
                                     -fx-background-color: white; -fx-font-size: 13px;"/>
                </VBox>

                <!-- ── Exercises section ─────────────────────────────── -->
                <HBox alignment="CENTER_LEFT">
                    <Label text="Exercises"
                           style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#handleAddExercise"
                            text="+ Add Exercise"
                            style="-fx-background-color: linear-gradient(to right, #3b82f6, #60a5fa);
                                   -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 14; -fx-padding: 10 22; -fx-cursor: hand;"/>
                </HBox>

                <!-- Exercise rows injected here at runtime -->
                <VBox fx:id="exerciseListBox" spacing="10.0"/>

                <!-- ── Save button ─────────────────────────────────── -->
                <Button maxWidth="Infinity"
                        onAction="#handleSave"
                        text="💾  Save Workout"
                        style="-fx-background-color: linear-gradient(to right, #10b981, #059669);
                               -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;
                               -fx-padding: 16; -fx-background-radius: 16; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
