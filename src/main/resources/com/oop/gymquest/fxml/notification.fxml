<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="360" spacing="0"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 10); -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-border-width: 1;"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.notifications.NotificationController">

    <Label text="Notifications" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-padding: 15; -fx-text-fill: #1e293b;"/>

    <Separator style="-fx-opacity: 0.3;"/>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-max-height: 400;">
        <VBox fx:id="notificationList" spacing="2" style="-fx-padding: 10; -fx-background-color: white;"/>
    </ScrollPane>

    <Separator style="-fx-opacity: 0.3;"/>

    <Button text="Mark all as read" maxWidth="Infinity"
            style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-padding: 12; -fx-cursor: hand; -fx-font-weight: bold;"/>
</VBox>