<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.ProfileViewController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #2C3E50; -fx-padding: 0 20 0 20;">
            <Label text="GymQuest" style="-fx-text-fill: #CC7722; -fx-font-size: 24px; -fx-font-weight: bold;" />
            <Label text=" | Member Profile" style="-fx-text-fill: white; -fx-font-size: 18px;" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="280.0" spacing="15.0" style="-fx-background-color: #F4F4F4; -fx-padding: 25; -fx-border-color: #CC7722; -fx-border-width: 0 2 0 0;">
            <Label text="ACCOUNT INFORMATION" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

            <VBox spacing="5">
                <Label text="Full Name" />
                <TextField fx:id="nameField" text="John Doe" />
            </VBox>

            <VBox spacing="5">
                <Label text="Email Address" />
                <TextField fx:id="emailField" text="john.doe@email.com" />
            </VBox>

            <VBox spacing="5">
                <Label text="Phone Number" />
                <TextField fx:id="phoneField" text="+63 912 345 6789" />
            </VBox>

            <VBox spacing="5">
                <Label text="Membership Status" />
                <Label text="ACTIVE - PREMIUM" style="-fx-text-fill: #CC7722; -fx-font-weight: bold;" />
            </VBox>

            <Button onAction="#handleSave" prefWidth="200" text="Save Changes"
                    style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="10.0" style="-fx-padding: 20;">
            <Label text="Recent Attendance History" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

            <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="dateCol" prefWidth="120.0" text="Date" />
                    <TableColumn fx:id="timeCol" prefWidth="100.0" text="Time" />
                    <TableColumn fx:id="trainerCol" prefWidth="150.0" text="Trainer" />
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>