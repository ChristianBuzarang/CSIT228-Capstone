<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<HBox spacing="30" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.dashboard.DashboardController">
    <VBox spacing="25" HBox.hgrow="ALWAYS">
        <!-- Welcome Card -->
        <HBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 35; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 20, 0, 0, 10);">
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label text="Welcome back, Champion! 🎯" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Ready to crush your goals today?" style="-fx-font-size: 15; -fx-text-fill: #64748b;"/>

                <HBox spacing="20" style="-fx-padding: 20 0 0 0;">
                    <VBox prefWidth="220" spacing="8" style="-fx-background-color: #dcf0ff; -fx-padding: 20; -fx-background-radius: 15;">
                        <Label text="Workouts Completed" style="-fx-text-fill: #1e3a8a;"/>
                        <Label text="2" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                    </VBox>
                    <VBox prefWidth="220" spacing="8" style="-fx-background-color: #fef9c3; -fx-padding: 20; -fx-background-radius: 15;">
                        <Label text="This Week" style="-fx-text-fill: #854d0e;"/>
                        <Label text="2" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #eab308;"/>
                    </VBox>
                </HBox>
            </VBox>
            <!-- Design requirement: Weightlifter icon -->
            <ImageView fitHeight="100" preserveRatio="true">
                <Image url="@/com/oop/gymquest/muscle.png"/>
            </ImageView>
        </HBox>

        <!-- Workouts Grid -->
        <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 30;">
            <Label text="Today's Workouts" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <GridPane hgap="20" vgap="20">
                <HBox spacing="15" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 15;" GridPane.columnIndex="0">
                    <StackPane style="-fx-background-color: #dcf0ff; -fx-padding: 12; -fx-background-radius: 10;">
                        <ImageView fitHeight="22" fitWidth="22"><Image url="@/com/oop/gymquest/check.png"/></ImageView>
                    </StackPane>
                    <VBox spacing="5">
                        <Label text="Full Body Blast" style="-fx-font-weight: bold;"/>
                        <Label text="Beginner • 30 min" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                </HBox>
                <HBox spacing="15" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 15;" GridPane.columnIndex="1">
                    <StackPane style="-fx-background-color: #dcf0ff; -fx-padding: 12; -fx-background-radius: 10;">
                        <ImageView fitHeight="22" fitWidth="22"><Image url="@/com/oop/gymquest/check.png"/></ImageView>
                    </StackPane>
                    <VBox spacing="5">
                        <Label text="Upper Body Power" style="-fx-font-weight: bold;"/>
                        <Label text="Beginner • 25 min" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                </HBox>
            </GridPane>
        </VBox>
    </VBox>

    <!-- Right Sidebar Widgets -->
    <VBox spacing="25" prefWidth="320">
        <VBox spacing="15" style="-fx-background-color: #f59e0b; -fx-background-radius: 25; -fx-padding: 30;">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 15; -fx-background-radius: 40;">
                    <ImageView fitHeight="25" fitWidth="25"><Image url="@/com/oop/gymquest/muscle.png"/></ImageView>
                </StackPane>
                <VBox>
                    <Label text="Current Streak" textFill="white"/><Label text="12 days" textFill="white" style="-fx-font-size: 34; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 30;">
            <Label text="Quick Stats" style="-fx-font-weight: bold; -fx-font-size: 18;"/>
            <VBox spacing="12">
                <Label text="Weekly Goal"/><ProgressBar progress="0.8" maxWidth="Infinity" prefHeight="8" style="-fx-accent: #3b82f6;"/>
                <Label text="Total Minutes"/><ProgressBar progress="0.6" maxWidth="Infinity" prefHeight="8" style="-fx-accent: #f59e0b;"/>
            </VBox>
        </VBox>

        <VBox spacing="15" alignment="CENTER" style="-fx-background-color: #3b82f6; -fx-background-radius: 25; -fx-padding: 35;">
            <ImageView fitHeight="45" fitWidth="45"><Image url="@/com/oop/gymquest/muscle.png"/></ImageView>
            <Label text="Keep it up!" textFill="white" style="-fx-font-weight: bold; -fx-font-size: 20;"/>
        </VBox>
    </VBox>
</HBox>