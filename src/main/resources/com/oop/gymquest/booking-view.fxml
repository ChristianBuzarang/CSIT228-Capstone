<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.gymquest.screens.booking.BookingController">
    <VBox spacing="20.0" styleClass="main-container">
        <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
        </padding>

        <!-- Header Card -->
        <VBox styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="title" text="Book a Training Session" />
                    <Label styleClass="subtitle" text="Select a date to see available trainers and time slots" />
                </VBox>
                <Label style="-fx-font-size: 48px;" text="📅" />
            </HBox>
        </VBox>

        <!-- Main Content Area -->
        <HBox spacing="20.0">
            <!-- Calendar Section -->
            <VBox prefWidth="450.0" spacing="15.0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Label fx:id="monthLabel" styleClass="month-label" text="Month Year" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#onPrevMonth" styleClass="nav-btn" text="‹" />
                    <Button onAction="#onNextMonth" styleClass="nav-btn" text="›" />
                </HBox>

                <!-- Day Headers -->
                <HBox fx:id="dayHeaders" spacing="4.0" alignment="CENTER">
                    <!-- Populated via code or static labels -->
                    <Label styleClass="day-header" text="Sun" />
                    <Label styleClass="day-header" text="Mon" />
                    <Label styleClass="day-header" text="Tue" />
                    <Label styleClass="day-header" text="Wed" />
                    <Label styleClass="day-header" text="Thu" />
                    <Label styleClass="day-header" text="Fri" />
                    <Label styleClass="day-header" text="Sat" />
                </HBox>

                <GridPane fx:id="calendarGrid" hgap="4.0" vgap="4.0" alignment="CENTER" />
            </VBox>

            <!-- Trainer/Details Panel -->
            <VBox fx:id="trainerPanel" prefWidth="400.0" spacing="16.0" HBox.hgrow="ALWAYS">
                <!-- Placeholder or Dynamic Content will be injected here -->
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>